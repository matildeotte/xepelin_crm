<% month_start = current_day.beginning_of_month %>
<% month_end = current_day.end_of_month %>

<div class="page-header">
  <div>
    <p class="eyebrow">Panel KAM</p>
    <h1>Tu cartera</h1>
    <p class="muted">
      Enfocado en clientes operados, monto financiado, participación de cartera y oportunidades de expansión desde datos SII.
    </p>
  </div>
  <%= link_to "Ver todas las empresas", companies_path, class: "button" %>
</div>

<section class="grid grid-4">
  <div class="card">
    <div class="eyebrow">Clientes operando</div>
    <div class="metric-value"><%= @operating_companies.size %>/<%= @portfolio_count %></div>
    <div class="metric-label"><%= percent_value(@operating_rate) %> operó en los últimos 30 días</div>
  </div>

  <div class="card">
    <div class="eyebrow">Monto financiado</div>
    <div class="metric-value"><%= clp_money(@financed_amount) %></div>
    <div class="metric-label">Mes actual</div>
  </div>

  <div class="card">
    <div class="eyebrow">Participación de cartera (SOW)</div>
    <div class="metric-value"><%= percent_value(@share_of_wallet) %></div>
    <div class="metric-label">Financiado por Xepelin / total de facturas visibles en SII</div>
  </div>

  <div class="card">
    <div class="eyebrow">Oportunidad de expansión</div>
    <div class="metric-value"><%= clp_money(@expansion_opportunity) %></div>
    <div class="metric-label">Monto visible en SII no financiado este mes</div>
  </div>
</section>

<section class="section grid grid-2">
  <div class="card">
    <div class="page-header">
      <div>
        <h2>Oportunidades de crecimiento</h2>
        <p class="muted">
          Clientes activos con facturas visibles en SII que aún no están siendo financiadas por Xepelin este mes.
        </p>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Empresa</th>
          <th>Estado</th>
          <th>SOW</th>
          <th>Oportunidad</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @growth_opportunities.each do |company| %>
          <tr>
            <td>
              <strong><%= company.legal_name %></strong><br>
              <span class="muted"><%= company.tax_id %></span>
            </td>
            <td><%= activation_badge(company) %></td>
            <td><%= percent_value(company.share_of_wallet(from: month_start, to: month_end)) %></td>
            <td><%= clp_money(company.expansion_opportunity(from: month_start, to: month_end)) %></td>
            <td><%= link_to "Detalle", company_path(company) %></td>
          </tr>
        <% end %>
        <% if @growth_opportunities.empty? %>
          <tr>
            <td colspan="5" class="muted">No hay oportunidades de crecimiento para este período.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="page-header">
      <div>
        <h2>Bloqueos de cobranza</h2>
        <p class="muted">
          Solo informativo: Cobranza gestiona la recuperación, pero las facturas vencidas pueden bloquear operaciones futuras.
        </p>
      </div>
      <%= link_to "Ver impagas", invoices_unpaid_path %>
    </div>

    <div class="grid grid-2">
      <div>
        <div class="eyebrow">Facturas impagas</div>
        <div class="metric-value"><%= @unpaid_invoices.size %></div>
      </div>
      <div>
        <div class="eyebrow">Monto vencido</div>
        <div class="metric-value"><%= clp_money(@overdue_amount) %></div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Empresa</th>
          <th>Pagador</th>
          <th>Vencimiento</th>
          <th>Monto</th>
        </tr>
      </thead>
      <tbody>
        <% @unpaid_invoices.first(5).each do |invoice| %>
          <tr>
            <td><%= link_to invoice.company.legal_name, company_path(invoice.company) %></td>
            <td><%= link_to invoice.debtor.legal_name, debtor_path(invoice.debtor) %></td>
            <td><%= invoice.due_date %></td>
            <td><%= clp_money(invoice.amount) %></td>
          </tr>
        <% end %>
        <% if @unpaid_invoices.empty? %>
          <tr>
            <td colspan="4" class="muted">No hay facturas financiadas impagas.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="section grid grid-2">
  <div class="card">
    <h2>Top clientes por monto financiado</h2>
    <table>
      <thead>
        <tr>
          <th>Empresa</th>
          <th>Financiado</th>
          <th>SOW</th>
          <th>Siguiente acción</th>
        </tr>
      </thead>
      <tbody>
        <% @top_financed_companies.each do |company| %>
          <tr>
            <td><%= link_to company.legal_name, company_path(company) %></td>
            <td><%= clp_money(company.financed_amount(from: month_start, to: month_end)) %></td>
            <td><%= percent_value(company.share_of_wallet(from: month_start, to: month_end)) %></td>
            <td><%= Company.human_enum_name(:next_best_action, company.next_best_action) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Ranking de expansión con SOW bajo</h2>
    <table>
      <thead>
        <tr>
          <th>Empresa</th>
          <th>SOW</th>
          <th>Volumen SII</th>
          <th>Oportunidad</th>
        </tr>
      </thead>
      <tbody>
        <% @low_sow_opportunities.each do |company| %>
          <tr>
            <td><%= link_to company.legal_name, company_path(company) %></td>
            <td><%= percent_value(company.share_of_wallet(from: month_start, to: month_end)) %></td>
            <td><%= clp_money(company.sii_volume(from: month_start, to: month_end)) %></td>
            <td><%= clp_money(company.expansion_opportunity(from: month_start, to: month_end)) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="section card">
  <h2>Resultados del equipo de riesgos</h2>
  <p class="muted">
    El KAM consume estas señales de elegibilidad. Riesgos, Cobranza y Fraude siguen siendo equipos responsables separados.
  </p>
  <table>
    <thead>
      <tr>
        <th>Empresa</th>
        <th>Pagador</th>
        <th>Estado</th>
        <th>Tipo de riesgo</th>
        <th>Motivo</th>
        <th>Evaluado</th>
      </tr>
    </thead>
    <tbody>
      <% @risk_constraints.each do |eligibility| %>
        <tr>
          <td><%= link_to eligibility.company.legal_name, company_path(eligibility.company) %></td>
          <td>
            <% if eligibility.debtor.present? %>
              <%= link_to eligibility.debtor.legal_name, debtor_path(eligibility.debtor) %>
            <% else %>
              Nivel empresa
            <% end %>
          </td>
          <td><%= risk_badge(eligibility) %></td>
          <td><%= RiskEligibility.human_enum_name(:risk_type, eligibility.risk_type) %></td>
          <td><%= eligibility.reason %></td>
          <td><%= eligibility.evaluated_at.to_date %></td>
        </tr>
      <% end %>
      <% if @risk_constraints.empty? %>
        <tr>
          <td colspan="6" class="muted">No hay restricciones de elegibilidad para esta cartera.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<div class="page-header">
  <div>
    <p class="eyebrow">Detalle del pagador</p>
    <h1><%= @debtor.legal_name %></h1>
    <p class="muted"><%= @debtor.tax_id %> · <%= @debtor.sector %></p>
  </div>
  <%= link_to "Volver a empresas", companies_path, class: "button button-secondary" %>
</div>

<section class="grid grid-4">
  <div class="card">
    <div class="eyebrow">Facturas Xepelin globales</div>
    <div class="metric-value"><%= @debtor.xepelin_invoice_count %></div>
    <div class="metric-label">En todas las carteras KAM</div>
  </div>

  <div class="card">
    <div class="eyebrow">Monto financiado global</div>
    <div class="metric-value"><%= clp_money(@debtor.global_financed_amount) %></div>
    <div class="metric-label">En todas las operaciones Xepelin</div>
  </div>

  <div class="card">
    <div class="eyebrow">Exposición abierta</div>
    <div class="metric-value"><%= clp_money(@debtor.open_exposure) %></div>
    <div class="metric-label">Facturas financiadas impagas</div>
  </div>

  <div class="card">
    <div class="eyebrow">Proxy de probabilidad de pago</div>
    <div class="metric-value">
      <% if @debtor.on_time_payment_rate.present? %>
        <%= percent_value(@debtor.on_time_payment_rate) %>
      <% else %>
        N/A
      <% end %>
    </div>
    <div class="metric-label"><%= @debtor.payment_probability_label %> según pagos históricos a tiempo</div>
  </div>
</section>

<section class="section card">
  <h2>Resultados de riesgos en tu cartera</h2>
  <table>
    <thead>
      <tr>
        <th>Empresa</th>
        <th>Estado</th>
        <th>Tipo de riesgo</th>
        <th>Motivo</th>
      </tr>
    </thead>
    <tbody>
      <% @risk_eligibilities.each do |eligibility| %>
        <tr>
          <td><%= link_to eligibility.company.legal_name, company_path(eligibility.company) %></td>
          <td><%= risk_badge(eligibility) %></td>
          <td><%= RiskEligibility.human_enum_name(:risk_type, eligibility.risk_type) %></td>
          <td><%= eligibility.reason %></td>
        </tr>
      <% end %>
      <% if @risk_eligibilities.empty? %>
        <tr>
          <td colspan="4" class="muted">No hay resultado de riesgos para este pagador en tu cartera.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="section card">
  <h2>Facturas vinculadas a tu cartera</h2>
  <p class="muted">
    La visibilidad detallada de facturas está limitada a empresas asignadas al KAM logueado.
  </p>
  <table>
    <thead>
      <tr>
        <th>Empresa</th>
        <th>Factura</th>
        <th>Fuente</th>
        <th>Monto</th>
        <th>Emisión</th>
        <th>Vencimiento</th>
        <th>Estado</th>
        <th>Pagada el</th>
      </tr>
    </thead>
    <tbody>
      <% @portfolio_invoices.each do |invoice| %>
        <tr>
          <td><%= link_to invoice.company.legal_name, company_path(invoice.company) %></td>
          <td><%= invoice.invoice_number %></td>
          <td><%= Invoice.human_enum_name(:source, invoice.source) %></td>
          <td><%= clp_money(invoice.amount) %></td>
          <td><%= invoice.issue_date %></td>
          <td><%= invoice.due_date %></td>
          <td><%= invoice_status_badge(invoice) %></td>
          <td><%= invoice.paid_on || "Pendiente" %></td>
        </tr>
      <% end %>
      <% if @portfolio_invoices.empty? %>
        <tr>
          <td colspan="8" class="muted">No hay facturas vinculadas a tus empresas asignadas.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

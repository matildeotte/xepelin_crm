<% month_start = @current_month_start %>
<% month_end = @current_month_end %>

<div class="page-header">
  <div>
    <p class="eyebrow">Detalle de empresa</p>
    <h1><%= @company.legal_name %></h1>
    <p class="muted">
      <%= @company.tax_id %> · <%= @company.sector %> · Creada <%= @company.created_at.to_date %>
    </p>
  </div>
  <div>
    <%= activation_badge(@company) %>
    <%= risk_badge(@latest_risk_eligibility) %>
  </div>
</div>

<section class="grid grid-4">
  <div class="card">
    <div class="eyebrow">Financiado este mes</div>
    <div class="metric-value"><%= clp_money(@company.financed_amount(from: month_start, to: month_end)) %></div>
    <div class="metric-label">KPI principal del KAM</div>
  </div>

  <div class="card">
    <div class="eyebrow">Volumen visible en SII</div>
    <div class="metric-value"><%= clp_money(@company.sii_volume(from: month_start, to: month_end)) %></div>
    <div class="metric-label">Facturas vistas a través de la conexión SII del cliente</div>
  </div>

  <div class="card">
    <div class="eyebrow">Participación de cartera (SOW)</div>
    <div class="metric-value"><%= percent_value(@company.share_of_wallet(from: month_start, to: month_end)) %></div>
    <div class="metric-label">Financiado por Xepelin / volumen visible en SII</div>
  </div>

  <div class="card">
    <div class="eyebrow">Oportunidad de expansión</div>
    <div class="metric-value"><%= clp_money(@company.expansion_opportunity(from: month_start, to: month_end)) %></div>
    <div class="metric-label">Monto visible no financiado este mes</div>
  </div>
</section>

<section class="section grid grid-3">
  <div class="card">
    <h3>Siguiente mejor acción</h3>
    <p><%= Company.human_enum_name(:next_best_action, @company.next_best_action) %></p>
    <p class="muted">
      Última operación financiada:
      <strong><%= @company.last_financed_on || "Sin operaciones financiadas aún" %></strong>
    </p>
  </div>

  <div class="card">
    <h3>Concentración de pagadores</h3>
    <div class="metric-value"><%= percent_value(@company.top_debtor_concentration) %></div>
    <p class="muted">
      Porcentaje del volumen visible total concentrado en la mayor relación con un pagador.
    </p>
  </div>

  <div class="card">
    <h3>Bloqueo de cobranza</h3>
    <div class="metric-value"><%= clp_money(@overdue_financed_amount) %></div>
    <p class="muted">
      Cobranza gestiona la recuperación. El KAM usa esto para entender si el cliente puede seguir operando.
    </p>
  </div>
</section>

<section class="section card">
    <h2>Resumen de salud AI</h2>
    <% if @latest_health_score.present? %>
      <div class="metric-value"><%= @latest_health_score.score %>/100</div>
      <p><%= @latest_health_score.summary %></p>
      <% if @latest_health_score.recommended_actions.present? %>
        <ul>
          <% @latest_health_score.recommended_actions.each do |action| %>
            <li><%= action %></li>
          <% end %>
        </ul>
      <% end %>
    <% else %>
      <p class="muted">
        Aún no hay resumen de salud generado. Aquí se puede mostrar la salida del LLM de la parte 2.
      </p>
    <% end %>
</section>

<section class="section card">
  <h2>Pricing y riesgo por relación con pagador</h2>
  <p class="muted">
    Las tasas se definen a nivel empresa-pagador. La elegibilidad de riesgos es un resultado externo consumido por Comercial.
  </p>
  <table>
    <thead>
      <tr>
        <th>Pagador</th>
        <th>Tasa mensual</th>
          <th>Límite aprobado</th>
        <th>Resultado de riesgo</th>
        <th>Motivo</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @pricing_agreements.each do |agreement| %>
        <% eligibility = @risk_eligibilities.detect { |item| item.debtor_id == agreement.debtor_id } %>
        <tr>
          <td>
            <strong><%= agreement.debtor.legal_name %></strong><br>
            <span class="muted"><%= agreement.debtor.tax_id %></span>
          </td>
          <td><%= percent_value(agreement.monthly_rate) %></td>
          <td><%= clp_money(agreement.approved_limit) %></td>
          <td><%= risk_badge(eligibility) %></td>
          <td><%= eligibility&.reason || "Sin restricción" %></td>
          <td><%= link_to "Detalle pagador", debtor_path(agreement.debtor) %></td>
        </tr>
      <% end %>
      <% if @pricing_agreements.empty? %>
        <tr>
          <td colspan="6" class="muted">Aún no hay condiciones comerciales para esta empresa.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="section card">
  <h2>Facturas financiadas</h2>
  <p class="muted">
    Estas son facturas operadas por Xepelin. El estado de pago es contexto útil, pero no es la principal responsabilidad del KAM.
  </p>
  <table>
    <thead>
      <tr>
        <th>Factura</th>
        <th>Pagador</th>
        <th>Monto</th>
        <th>Financiada el</th>
        <th>Vencimiento</th>
        <th>Estado</th>
        <th>Pagada el</th>
        <th>Tasa moratoria</th>
      </tr>
    </thead>
    <tbody>
      <% @financed_invoices.each do |invoice| %>
        <tr>
          <td><%= invoice.invoice_number %></td>
          <td><%= link_to invoice.debtor.legal_name, debtor_path(invoice.debtor) %></td>
          <td><%= clp_money(invoice.amount) %></td>
          <td><%= invoice.financed_on %></td>
          <td><%= invoice.due_date %></td>
          <td><%= invoice_status_badge(invoice) %></td>
          <td><%= invoice.paid_on || "Pendiente" %></td>
          <td><%= percent_value(invoice.moratory_monthly_rate) %></td>
        </tr>
      <% end %>
      <% if @financed_invoices.empty? %>
        <tr>
          <td colspan="8" class="muted">Aún no hay facturas financiadas.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="section card">
  <h2>Facturas visibles en SII no financiadas por Xepelin</h2>
  <p class="muted">
    Esta es la oportunidad central de Growth: facturas observadas desde el scraper SII del cliente que no fueron operadas con Xepelin.
  </p>
  <table>
    <thead>
      <tr>
        <th>Factura</th>
        <th>Pagador</th>
        <th>Monto</th>
        <th>Emisión</th>
        <th>Vencimiento</th>
        <th>Acción sugerida</th>
      </tr>
    </thead>
    <tbody>
      <% @opportunity_invoices.each do |invoice| %>
        <% eligibility = @risk_eligibilities.detect { |item| item.debtor_id == invoice.debtor_id } %>
        <tr>
          <td><%= invoice.invoice_number %></td>
          <td><%= link_to invoice.debtor.legal_name, debtor_path(invoice.debtor) %></td>
          <td><%= clp_money(invoice.amount) %></td>
          <td><%= invoice.issue_date %></td>
          <td><%= invoice.due_date %></td>
          <td>
            <% if eligibility&.not_eligible? %>
              Esperar a riesgos: <%= eligibility.reason %>
            <% elsif eligibility&.in_review? %>
              Hacer seguimiento con riesgos antes de ofrecer.
            <% else %>
              Ofrecer financiamiento para esta relación con pagador.
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @opportunity_invoices.empty? %>
        <tr>
          <td colspan="6" class="muted">No hay facturas solo SII para esta empresa.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="section grid grid-2">
  <div class="card">
    <h2>Agregar interacción</h2>
    <%= form_with model: [@company, @interaction], local: true do |form| %>
      <div class="form-row">
        <%= form.label :kind %>
        <%= form.select :kind, Interaction.kinds.keys.map { |kind| [Interaction.human_enum_name(:kind, kind), kind] } %>
      </div>
      <div class="form-row">
        <%= form.label :summary %>
        <%= form.text_area :summary, placeholder: "Ejemplo: se conversó una oportunidad de financiamiento para facturas SII pendientes." %>
      </div>
      <%= form.submit "Agregar interacción" %>
    <% end %>
  </div>

  <div class="card">
    <h2>Interacciones recientes</h2>
    <table>
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Tipo</th>
          <th>Resumen</th>
        </tr>
      </thead>
      <tbody>
        <% @interactions.each do |interaction| %>
          <tr>
            <td><%= interaction.created_at.to_date %></td>
            <td><%= Interaction.human_enum_name(:kind, interaction.kind) %></td>
            <td><%= interaction.summary %></td>
          </tr>
        <% end %>
        <% if @interactions.empty? %>
          <tr>
            <td colspan="3" class="muted">Aún no hay interacciones.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="page-header">
  <div>
    <p class="eyebrow">Bloqueos operacionales</p>
    <h1>Facturas financiadas impagas</h1>
    <p class="muted">
      Estas facturas son responsabilidad de Cobranza, pero pueden afectar si un cliente puede seguir operando con Xepelin.
    </p>
  </div>
  <%= link_to "Volver al panel", root_path, class: "button button-secondary" %>
</div>

<section class="grid grid-3">
  <div class="card">
    <div class="eyebrow">Facturas impagas</div>
    <div class="metric-value"><%= @invoices.size %></div>
  </div>
  <div class="card">
    <div class="eyebrow">Monto pendiente</div>
    <div class="metric-value"><%= clp_money(@invoices.where(status: "pending").sum(:amount)) %></div>
  </div>
  <div class="card">
    <div class="eyebrow">Monto vencido</div>
    <div class="metric-value"><%= clp_money(@invoices.where(status: "overdue").sum(:amount)) %></div>
  </div>
</section>

<section class="section card">
  <table>
    <thead>
      <tr>
        <th>Empresa</th>
        <th>Pagador</th>
        <th>Factura</th>
        <th>Monto</th>
        <th>Vencimiento</th>
        <th>Estado</th>
        <th>Días vencida</th>
        <th>Acción sugerida para KAM</th>
      </tr>
    </thead>
    <tbody>
      <% @invoices.each do |invoice| %>
        <tr>
          <td><%= link_to invoice.company.legal_name, company_path(invoice.company) %></td>
          <td><%= link_to invoice.debtor.legal_name, debtor_path(invoice.debtor) %></td>
          <td><%= invoice.invoice_number %></td>
          <td><%= clp_money(invoice.amount) %></td>
          <td><%= invoice.due_date %></td>
          <td><%= invoice_status_badge(invoice) %></td>
          <td><%= invoice.days_overdue %></td>
          <td>
            <% if invoice.overdue? %>
              Coordinar contexto con Cobranza antes de ofrecer una nueva operación.
            <% else %>
              Monitorear con Cobranza; mantener cadencia comercial si riesgos lo permite.
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @invoices.empty? %>
        <tr>
          <td colspan="8" class="muted">No hay facturas financiadas impagas en tu cartera.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

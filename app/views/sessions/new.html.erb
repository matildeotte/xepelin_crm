<div class="grid grid-2" style="align-items: center; min-height: 70vh;">
  <section>
    <p class="eyebrow">Growth CRM</p>
    <h1>Operate more clients, increase financed amount, and grow share of wallet.</h1>
    <p class="muted">
      This CRM is focused on KAM execution: portfolio activation, financed amount, SII-based opportunity, and Risk team outputs.
    </p>
  </section>

  <section class="card">
    <h2>Sign in</h2>
    <p class="muted">Use Google OAuth to access your assigned portfolio.</p>
    <%= button_to "Continue with Google", "/auth/google_oauth2", method: :post %>
  </section>
</div>
